# This file contains the configuration for the run.sh script. It follows the
# Bash syntax and is sourced by the script to access the variables. Variables
# are mandatory unless marked with [brackets].

###
## Configuration parameters
###

# WORKDIR: path to directory where shared volumes will be created
WORKDIR=../_original

# REPEAT: number of campaigns to run per program (per fuzzer)
REPEAT=5

# [WORKER_POOL]: a space-separated list of logical cores to allocate
WORKER_POOL="$(seq 70 110)"

# [GLOBAL_FUZZARGS]: extra arguments passed to all fuzzers regardless of fuzzer/target
GLOBAL_FUZZARGS="--analysis-mode"

# FUZZERS: an array of fuzzer names (from magma/fuzzers/*) to evaluate
FUZZERS=(angora-reusing)

# [fuzzer_TARGETS]: an array of target names (from magma/targets/*) to fuzz with
angora_original_TARGETS=(exiv2 tiffsplit)
angora_TARGETS=(exiv2 tiffsplit)
angora_reusing_TARGETS=(tiffsplit)

# [target_SEED]: single seed directory applied to all trials
exiv2_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/exiv2/saturated_seed
flvmeta_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/flvmeta/saturated_seed
infotocap_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/infotocap/saturated_seed
mp3gain_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/mp3gain/saturated_seed
mp42aac_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/mp42aac/saturated_seed
objdump_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/objdump/saturated_seed
pdftotext_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/pdftotext/saturated_seed
tcpdump_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/tcpdump/saturated_seed
tiffsplit_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/tiffsplit/saturated_seed
jq_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/jq/saturated_seed
imginfo_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora/imginfo/saturated_seed
