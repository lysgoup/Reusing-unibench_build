# This file contains the configuration for the run.sh script. It follows the
# Bash syntax and is sourced by the script to access the variables. Variables
# are mandatory unless marked with [brackets].

###
## Configuration parameters
###

# WORKDIR: path to directory where shared volumes will be created
WORKDIR=../_ffmpeg

# REPEAT: number of campaigns to run per program (per fuzzer)
REPEAT=1

# [WORKER_POOL]: a space-separated list of logical cores to allocate
WORKER_POOL="$(seq 0 190)"

# FUZZERS: an array of fuzzer names (from magma/fuzzers/*) to evaluate
FUZZERS=(angora-reusing)

# [fuzzer_TARGETS]: an array of target names (from magma/targets/*) to fuzz with
angora_TARGETS=(exiv2 infotocap mp3gain mp42aac pdftotext wav2swf)
angora_reusing_TARGETS=(ffmpeg)

# [target_SEED]: single seed directory applied to all trials
exiv2_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/exiv2/saturated_seed
ffmpeg_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/ffmpeg/saturated_seed
flvmeta_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/flvmeta/saturated_seed
infotocap_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/infotocap/saturated_seed
mp3gain_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/mp3gain/saturated_seed
mp42aac_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/mp42aac/saturated_seed
objdump_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/objdump/saturated_seed
pdftotext_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/pdftotext/saturated_seed
tcpdump_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/tcpdump/saturated_seed
tiffsplit_SEED=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/tiffsplit/saturated_seed

# [target_SEEDS]: per-trial seed directories (array). SEEDS[i] is used for trial i.
# If an element is missing for a given trial index, falls back to target_SEED.
SAT=/home/yunseo/Reusing_mut/Reusing-unibench_build/_saturation/ar/angora
